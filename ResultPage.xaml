<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizMauiApp.ResultPage"
             Title="Résultat final">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="24"
        Padding="30">

        <!-- Trophy icon -->
        <Label Text="🏆"
               FontSize="64"
               HorizontalTextAlignment="Center" />

        <!-- Title -->
        <Label Text="Résultat final"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <!-- Dynamic score label -->
        <Label x:Name="ScoreLabel"
               Text="Score : ..."
               FontSize="26"
               TextColor="#512BD4"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <!-- Motivational message -->
        <Label x:Name="MessageLabel"
               Text=""
               FontSize="16"
               TextColor="Gray"
               HorizontalTextAlignment="Center" />

        <!-- Back to home button -->
        <Button Text="🏠  Retour à l'accueil"
                Clicked="OnGoHomeClicked"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                FontSize="16"
                Padding="20,12"
                Margin="0,20,0,0" />

    </VerticalStackLayout>

</ContentPage>