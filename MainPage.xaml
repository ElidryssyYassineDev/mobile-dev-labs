<?xml version="1.0" encoding="utf-8" ?>
    
 <ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizMauiApp.MainPage"
             Title="Accueil">
    <ScrollView>
        <VerticalStackLayout Padding="30"
                             Spacing="25"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">

            <Label Text="🏆"
               FontSize="80"
               HorizontalOptions="Center"/>
            <Label Text="Quiz Challenge"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="DarkBlue" />
             <Label Text="Bienvenue dans votre application mobile de quiz."
                       FontSize="18"
                       HorizontalTextAlignment="Center" />
             <Label Text="Testez vos connaissances, améliorez votre score et relevez le défi."
                    FontSize="16"
                    HorizontalTextAlignment="Center"/>
             <Button Text="Commencer le quiz"
                     FontSize="18"
                     HeightRequest="55"
                     WidthRequest="220"
                     CornerRadius="12"
                     BackgroundColor="DarkBlue"
                     TextColor="White"
                     Clicked="OnStartClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>