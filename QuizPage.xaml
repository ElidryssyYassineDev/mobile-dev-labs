<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
x:Class="QuizMauiApp.QuizPage"
Title="Quiz">
    <VerticalStackLayout Padding="30" Spacing="20">
        <Label x:Name="QuestionLabel"
Text="Question ici"
FontSize="24"
FontAttributes="Bold"
HorizontalTextAlignment="Center" />
        <Button Text="Réponse 1" Clicked="OnAnswerClicked"/>
        <Button Text="Réponse 2" Clicked="OnAnswerClicked"/>
        <Button Text="Réponse 3" Clicked="OnAnswerClicked"/>
        <Button Text="Réponse 4" Clicked="OnAnswerClicked"/>
    </VerticalStackLayout>
</ContentPage>