<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizMauiApp.CategoriesPage"
             Title="Catégories">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <Label Text="Choisissez une catégorie"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,10" />

        <!-- Each button Text MUST match the switch/case keys exactly -->
        <Button Text="Culture générale"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                FontSize="18"
                Clicked="OnCategoryClicked" />

        <Button Text="Mathématiques"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                FontSize="18"
                Clicked="OnCategoryClicked" />

        <Button Text="Informatique"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                FontSize="18"
                Clicked="OnCategoryClicked" />

        <Button Text="Langues"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                FontSize="18"
                Clicked="OnCategoryClicked" />

    </VerticalStackLayout>

</ContentPage>