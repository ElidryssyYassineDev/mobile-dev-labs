<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pedometer"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#993C1D"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYPE_STEP_COUNTER — cumulative hardware step counter since last reboot"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp"/>

        <!-- Permission status -->
        <TextView
            android:id="@+id/tv_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF8E1"
            android:padding="12dp"
            android:textSize="13sp"
            android:textColor="#5D4037"
            android:text="Checking permission…"
            android:layout_marginBottom="16dp"
            android:elevation="1dp"/>

        <!-- Session steps — big display -->
        <TextView
            android:id="@+id/tv_session_steps"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#993C1D"
            android:background="#FAECE7"
            android:text="Session steps: 0"
            android:layout_marginBottom="8dp"
            android:elevation="2dp"/>

        <!-- Total steps since reboot -->
        <TextView
            android:id="@+id/tv_total_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#1A1A2E"
            android:text="Total since reboot: —"
            android:layout_marginBottom="8dp"
            android:elevation="1dp"/>

        <!-- Distance estimate -->
        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#1A1A2E"
            android:text="Distance: 0.0 m"
            android:layout_marginBottom="8dp"
            android:elevation="1dp"/>

        <!-- Calorie estimate -->
        <TextView
            android:id="@+id/tv_calories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#1A1A2E"
            android:text="Calories burned: ~0.0 kcal"
            android:layout_marginBottom="16dp"
            android:elevation="1dp"/>

        <!-- Reset button -->
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Reset session"
            android:backgroundTint="#D85A30"
            android:layout_marginBottom="8dp"/>

        <!-- Sensor info -->
        <TextView
            android:id="@+id/tv_sensor_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#666666"
            android:text="Sensor info: —"
            android:elevation="1dp"/>

    </LinearLayout>
</ScrollView>